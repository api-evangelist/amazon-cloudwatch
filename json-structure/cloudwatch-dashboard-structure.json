{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/amazon-cloudwatch/refs/heads/main/json-structure/cloudwatch-dashboard-structure.json",
  "name": "Dashboard",
  "description": "Represents a CloudWatch dashboard",
  "type": "object",
  "properties": {
    "dashboardName": {
      "type": "string",
      "description": "The name of the dashboard"
    },
    "dashboardArn": {
      "type": "string",
      "description": "The ARN of the dashboard"
    },
    "lastModified": {
      "type": "datetime",
      "description": "The time stamp of when the dashboard was last modified"
    },
    "size": {
      "type": "int32",
      "description": "The size of the dashboard in bytes"
    }
  }
}